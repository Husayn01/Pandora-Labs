{
  "name": "pandora-labs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:migrations": "node scripts/check-migrations.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:migrations && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.10.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "esbuild": ">=0.28.1",
    "ws": ">=8.21.0",
    "tar": ">=7.5.16"
  }
}
