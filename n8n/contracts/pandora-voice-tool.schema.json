{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PandoraVoiceToolRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "correlationId", "organizationId", "actorId", "role", "channel", "conversationId", "tool", "parameters", "authContext", "entitlementSnapshot"],
  "properties": {
    "requestId": { "type": "string", "minLength": 8, "maxLength": 128 },
    "correlationId": { "type": "string", "format": "uuid" },
    "organizationId": { "type": "string", "format": "uuid" },
    "actorId": { "type": "string", "format": "uuid" },
    "role": { "enum": ["owner", "admin", "member", "viewer"] },
    "channel": { "enum": ["voice"] },
    "conversationId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "callSid": { "type": "string", "maxLength": 128 },
    "tool": { "enum": ["get_business_context", "prepare_action", "check_calendar_availability", "create_email_draft", "create_calendar_draft", "confirm_action", "get_action_status"] },
    "parameters": { "type": "object" },
    "authContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verificationLevel"],
      "properties": { "verificationLevel": { "const": "signed_voice_context" } }
    },
    "entitlementSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan"],
      "properties": { "plan": { "enum": ["free", "solo", "business", "scale"] } }
    }
  }
}
