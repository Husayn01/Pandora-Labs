# Pandora Labs - Environment Variables
# Copy this file to .env and fill in your values.

# Supabase browser client
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Supabase server API functions
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Site URL used for OAuth redirects and CORS in production
SITE_URL=http://localhost:5173
OAUTH_STATE_SECRET=replace-with-a-long-random-secret

# AI providers
GEMINI_API_KEY=your-gemini-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# OAuth connectors
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
NOTION_CLIENT_ID=your-notion-oauth-client-id
NOTION_CLIENT_SECRET=your-notion-oauth-client-secret

# WhatsApp webhook
WHATSAPP_VERIFY_TOKEN=replace-with-your-meta-webhook-token
