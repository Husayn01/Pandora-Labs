# Browser-safe Supabase configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Server-only Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# Site security and redirects
SITE_URL=http://localhost:5173

# Shared n8n orchestration entry point
N8N_PANDORA_COMMAND_WEBHOOK_URL=https://your-n8n.example/webhook/pandora-command
N8N_PANDORA_VOICE_WEBHOOK_URL=https://your-n8n.example/webhook/pandora-voice-tool
N8N_PANDORA_WEBHOOK_SECRET=replace-with-at-least-32-random-bytes
PANDORA_DEFAULT_TIMEZONE=Africa/Lagos

# ElevenLabs protected web voice and signed post-call webhook
ELEVENLABS_API_KEY=server-only-elevenlabs-key
ELEVENLABS_AGENT_ID=your-pandora-agent-id
ELEVENLABS_WEBHOOK_SECRET=your-elevenlabs-webhook-signing-secret
ELEVENLABS_INIT_WEBHOOK_SECRET=replace-with-at-least-32-random-bytes
ELEVENLABS_TOOL_PROXY_SECRET=replace-with-at-least-32-random-bytes
ELEVENLABS_ENVIRONMENT=development

# Telephony identity verification and inbound-number validation
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=server-only-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PANDORA_TWILIO_NUMBER=+1xxxxxxxxxx
CHANNEL_IDENTITY_PEPPER=replace-with-at-least-32-random-bytes
VOICE_CONTEXT_SECRET=replace-with-at-least-32-random-bytes

# Google Workspace OAuth. Add the exact callback URL in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Paystack hosted subscriptions and signed webhooks
PAYSTACK_SECRET_KEY=sk_test_or_live_value
PAYSTACK_SOLO_PLAN_CODE=PLN_solo
PAYSTACK_BUSINESS_PLAN_CODE=PLN_business
PAYSTACK_SCALE_PLAN_CODE=PLN_scale

# Set these separately in Supabase Edge Function secrets, not Vercel:
# PANDORA_CONNECTOR_SERVICE_SECRET
# GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET
