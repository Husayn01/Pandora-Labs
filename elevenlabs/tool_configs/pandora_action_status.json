{
  "type": "webhook",
  "name": "pandora_action_status",
  "description": "Check a previously confirmed action when execution is asynchronous, interrupted, pending, or uncertain. Never claim success unless this tool returns succeeded.",
  "method": "POST",
  "url": "${PANDORA_BASE_URL}/api/voice/action",
  "timeout_seconds": 8,
  "headers": {
    "X-Pandora-Voice-Context": "{{secret__voice_context_token}}",
    "X-Pandora-ElevenLabs-Secret": "${AUTH_CONNECTION_SECRET}"
  },
  "body_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["tool", "actionId"],
    "properties": {
      "tool": { "const": "action_status" },
      "actionId": { "type": "string", "format": "uuid" }
    }
  }
}
